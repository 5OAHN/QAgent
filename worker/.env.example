PORT=8001
WORKER_BASE_URL=http://localhost:8001
FRONTEND_URL=https://your-app.vercel.app   # 예약 실행 완료 알림에 결과 링크를 붙이려면 설정
ANTHROPIC_API_KEY=sk-ant-...   # 선택사항 - Fail 분석 및 자연어 모드
HEADLESS=false                  # false: 브라우저 창 표시 (로컬 테스트용)
INITIAL_APP_PASSWORD=qagent           # 일반 로그인(조회용) 비밀번호 — 최초 1회만 적용됨
INITIAL_ADMIN_PASSWORD=qagent-admin   # 새 테스트 생성(API 크레딧 소비) 보호용 관리자 비밀번호 — 최초 1회만 적용됨
